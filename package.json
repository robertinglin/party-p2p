{
  "name": "party-p2p",
  "version": "0.1.1",
  "description": "A statically hosted event PWA using PeerJS/WebRTC and a host-run room peer.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertinglin/party-p2p.git"
  },
  "bin": {
    "party-p2p": "./bin/party-p2p.cjs"
  },
  "files": [
    "bin",
    "host/*.cjs",
    "scripts",
    ".partyrc.example",
    "ARCHITECTURE.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite --config client/vite.config.ts --host 0.0.0.0",
    "build": "tsc --project client/tsconfig.json && vite build --config client/vite.config.ts",
    "check": "tsc --project client/tsconfig.json",
    "test": "npm run check && node --test tests/partyRc.test.cjs tests/host-moderation.test.cjs tests/client-eventTime.test.cjs tests/client-manifest.test.cjs tests/client-roomLink.test.cjs tests/client-storage.test.cjs",
    "preview": "vite preview --config client/vite.config.ts --host 0.0.0.0",
    "start": "node scripts/start-host.cjs",
    "host": "node host/host.cjs",
    "host:demo": "node host/host.cjs --room rooftop-disco --title \"Rooftop Disco\" --date \"2026-06-20\" --time \"8:00 PM\" --location \"Brooklyn rooftop\"",
    "clean": "rm -rf client/dist host/data"
  },
  "dependencies": {
    "@roamhq/wrtc": "^0.10.0",
    "peerjs": "^1.5.5",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0",
    "xhr2": "^0.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
